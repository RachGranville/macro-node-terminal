# Copie este arquivo para .env.local e preencha com suas chaves reais.
# .env.local está no .gitignore — nunca será commitado.

# Finnhub (cotações de ETFs). Plano free: 60 req/min, só tickers US-listed.
# https://finnhub.io/register
FINNHUB_API_KEY=

# NewsAPI (manchetes). Plano free: 100 req/dia, funciona apenas em localhost.
# https://newsapi.org/register
NEWS_API_KEY=
